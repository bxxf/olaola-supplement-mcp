{
  "name": "olaola-supplement-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for OlaOla supplement discovery, product composition checks, and quick-buy cart planning",
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "mcp",
    "olaola",
    "supplements",
    "shopping",
    "typescript"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc --outDir dist --rootDir src",
    "start": "node dist/server.js",
    "start:http": "MCP_TRANSPORT=http node dist/server.js",
    "dev": "tsx src/server.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/server.ts",
    "deploy:cloudflare": "npx wrangler deploy --config wrangler.toml",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "smoke:live": "tsx scripts/smoke-live.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "domhandler": "^6.0.1",
    "domutils": "^4.0.2",
    "hono": "^4.12.18",
    "htmlparser2": "^12.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^24.12.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
